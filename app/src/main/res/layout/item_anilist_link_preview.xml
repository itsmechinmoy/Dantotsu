<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/previewCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="16dp"
    android:backgroundTint="#B3000000"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/previewCoverImage"
                android:layout_width="60dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/roundedImageViewSmall"
                tools:ignore="ContentDescription"
                tools:srcCompat="@tools:sample/backgrounds/scenic" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/previewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/poppins_bold"
                android:maxLines="2"
                android:textColor="@color/bg_white"
                android:textSize="15sp"
                tools:text="Frieren: Beyond Journey's End" />
            <TextView
                android:id="@+id/previewFormatStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:alpha="0.8"
                android:fontFamily="@font/poppins_semi_bold"
                android:textColor="@color/bg_white"
                android:textSize="12sp"
                tools:text="TV · Finished" />

            <TextView
                android:id="@+id/previewSeasonScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:alpha="0.7"
                android:fontFamily="@font/poppins_semi_bold"
                android:textColor="@color/bg_white"
                android:textSize="12sp"
                tools:text="Fall 2023 · 91%" />

            <TextView
                android:id="@+id/previewEpisodes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:alpha="0.7"
                android:fontFamily="@font/poppins_semi_bold"
                android:textColor="@color/bg_white"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="28 Episodes"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
